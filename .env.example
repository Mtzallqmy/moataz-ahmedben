# =====================================================
# معتز العلقمي - Environment Variables (Vercel Ready)
# =====================================================
# 
# تعليمات:
# 1. انسخ هذا الملف إلى .env (للتطوير المحلي فقط)
# 2. لا تقم برفع ملف .env إلى GitHub أبداً
# 3. أضف هذه المتغيرات يدوياً في Vercel → Settings → Environment Variables
# 4. بعد الاستخدام، قم بتغيير ENCRYPTION_KEY وكلمات المرور
#
# =====================================================

# Public Supabase configuration (safe to expose in the browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Server-only Supabase configuration (never use VITE_ prefix)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Server-only 32+ character secret used to encrypt provider API keys
ENCRYPTION_KEY=GENERATE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Optional platform defaults; user provider keys are stored encrypted in Supabase
OPENAI_API_KEY=
GEMINI_API_KEY=

# Vercel (لـ GitHub Actions - اختياري)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
