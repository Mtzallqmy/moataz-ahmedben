# =====================================================
# Moataz AI — Vercel / Local environment
# Never commit real values.
# =====================================================

# Browser-safe Supabase values
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SB_PUBLISHABLE_KEY
# Legacy fallback only; leave unset when using a publishable key.
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase values
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SB_PUBLISHABLE_OR_LEGACY_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 32+ characters; encrypts provider API keys with AES-256-GCM
ENCRYPTION_KEY=GENERATE_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS

# Authentication behavior
ALLOW_PUBLIC_SIGNUP=false
USERNAME_EMAIL_DOMAIN=users.moataz.invalid

# One-time owner bootstrap. Delete token/password after successful bootstrap and redeploy.
BOOTSTRAP_OWNER_EMAIL=mtzallqmy@gmail.com
BOOTSTRAP_OWNER_PASSWORD=
BOOTSTRAP_TOKEN=

# Provider runtime
APP_URL=https://YOUR_DOMAIN.example
PROVIDER_TIMEOUT_MS=45000
ALLOW_INSECURE_PROVIDER_URLS=false

# Optional Vercel GitHub Action deployment values
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
